rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: User is authenticated and owns the data
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // --- Extracted Job Roles ---
    match /extractedJobRoles/{jobRoleId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }

    // --- Job Screening Results ---
    match /jobScreeningResults/{resultId} {
      // 404 fix: Ensure reads are allowed if you own it
      allow read, update, delete: if isOwner(resource.data.userId);
      // Allow creation if you claim it as yours
      allow create: if isOwner(request.resource.data.userId);
    }

    // --- ATS Score Results ---
    match /atsScoreResults/{resultId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }

    // --- Interview Question Sets ---
    match /interviewQuestionSets/{setId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }

  }
}
